generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Url {
  id          String   @id @default(cuid())
  shortCode   String   @unique
  originalUrl String
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}